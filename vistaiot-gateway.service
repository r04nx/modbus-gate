[Unit]
Description=VistaIOT Gateway Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/modbus-gate/backend
Environment="PATH=/opt/modbus-gate/backend/venv/bin"
Environment="BUFFER_DIR=/opt/modbus-gate/buffered_data"
ExecStart=/opt/modbus-gate/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
