[Unit]
Description=VistaIOT Backend Service
After=network.target

[Service]
User=rohan
WorkingDirectory=/home/rohan/Public/warp/modbus-gate/backend
ExecStart=/home/rohan/Public/warp/modbus-gate/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
